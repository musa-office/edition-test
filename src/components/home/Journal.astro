---
// ============================================================
//  Journal — editorial article cards (featured + secondary),
//  driven by live Shopify blog articles with a static fallback.
// ============================================================
import type { Article } from '~/lib/shopify/services/content';
import { JOURNAL_FALLBACK, JOURNAL_FALLBACK_IMAGES } from '~/config/home';

interface Props {
  articles?: Article[];
}
const { articles = [] } = Astro.props;

const fmtDate = (iso?: string) =>
  iso
    ? new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(new Date(iso))
    : '';

// Map live articles (or fall back to the static editorial set). Live
// article images are remote Shopify URLs; the fallback images are
// imported assets, so we read their resolved `.src` to keep one string
// shape for the <img> below.
const live = articles.slice(0, 4).map((a, i) => ({
  href: `/journal/${a.handle}`,
  img: a.image?.url ?? JOURNAL_FALLBACK_IMAGES[i % JOURNAL_FALLBACK_IMAGES.length].src,
  cat: a.author ?? 'The Journal',
  date: fmtDate(a.publishedAt),
  title: a.title,
  excerpt: a.excerpt ?? '',
}));

const fallback = JOURNAL_FALLBACK.map((f) => ({ ...f, img: f.img.src }));

const items = live.length ? live : fallback;
const featured = items[0];
const secondary = items.slice(1, 4);
---

<section class="section" id="journal">
  <div class="wrap">
    <div class="sec-head center reveal" style="margin-bottom:56px;">
      <div>
        <span class="eyebrow center">The Journal</span>
        <h2 class="h-sec">Style Notes &amp; <em>Stories</em></h2>
      </div>
    </div>

    <div class="journal-grid">
      <article class="journal-featured reveal">
        <a href={featured.href} class="journal-feat-img-wrap">
          <img src={featured.img} alt={featured.title} loading="lazy" />
          <span class="journal-feat-cat-badge">{featured.cat}</span>
        </a>
        <div class="journal-feat-body">
          <div class="journal-feat-meta">
            <span>{featured.date}</span>
          </div>
          <h3 class="journal-feat-title">{featured.title}</h3>
          <p class="journal-feat-excerpt">{featured.excerpt}</p>
          <a href={featured.href} class="journal-read-link">Read Article
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
          </a>
        </div>
      </article>

      <div class="journal-secondary reveal d1">
        {
          secondary.map((a) => (
            <article class="journal-sec-card">
              <a href={a.href} class="journal-sec-img-wrap"><img src={a.img} alt={a.title} loading="lazy" /></a>
              <div class="journal-sec-body">
                <div class="journal-sec-meta">
                  <span class="journal-sec-cat">{a.cat}</span><span class="journal-meta-sep">·</span>
                  <span class="journal-sec-date">{a.date}</span>
                </div>
                <h3 class="journal-sec-title">{a.title}</h3>
                <p class="journal-sec-excerpt">{a.excerpt}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div style="text-align:center; margin-top: clamp(40px,5vw,64px);">
      <a class="btn-line" href="/journal">Read the Journal</a>
    </div>
  </div>
</section>
