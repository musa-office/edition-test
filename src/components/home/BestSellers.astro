---
// ============================================================
//  BestSellers — section head + horizontal product rail (live).
// ============================================================
import type { ProductCard } from "~/lib/shopify/types";
import ProductCardComp from "~/components/product/ProductCard.astro";

interface Props {
  products: ProductCard[];
}
const { products } = Astro.props;
---

<section class="section">
  <div class="wrap">
    <div class="sec-head reveal">
      <div>
        <span class="eyebrow">Most Wanted</span>
        <h2 class="h-sec">Best <em>Sellers</em></h2>
      </div>
      <div class="rail-nav">
        <button
          class="rail-arrow"
          data-rail-prev
          aria-label="Previous products"
        >
          <svg
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg
          >
        </button>
        <button class="rail-arrow" data-rail-next aria-label="Next products">
          <svg
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
        </button>
      </div>
    </div>

    <div class="sellers-rail reveal d1" data-rail>
      {products.map((p) => <ProductCardComp product={p} />)}
    </div>
  </div>
</section>

<script>
  const rail = document.querySelector("[data-rail]") as HTMLElement | null;
  const step = () => Math.min(rail?.clientWidth ?? 320, 360);
  document
    .querySelector("[data-rail-prev]")
    ?.addEventListener("click", () =>
      rail?.scrollBy({ left: -step(), behavior: "smooth" }),
    );
  document
    .querySelector("[data-rail-next]")
    ?.addEventListener("click", () =>
      rail?.scrollBy({ left: step(), behavior: "smooth" }),
    );
</script>
