---
// ============================================================
//  FeaturedShowcase — "Explore the Edit" featured categories.
//  A centered section header over a 4-card editorial grid
//  (mirrors Editorial Website / Editorial Homepage.html).
//
//  Content is prop-driven: defaults live in src/config/home.ts
//  (FEATURED_SHOWCASE). Pass `eyebrow` / `heading` / `panels`
//  to reuse this section anywhere without editing the markup.
//  Links route to collection PLPs (remap handles in the config).
// ============================================================
import { Image } from 'astro:assets';
import { FEATURED_SHOWCASE, type FeaturePanel } from '~/config/home';

interface Props {
  eyebrow?: string;
  heading?: { lead: string; em: string };
  panels?: FeaturePanel[];
}

const {
  eyebrow = FEATURED_SHOWCASE.eyebrow,
  heading = FEATURED_SHOWCASE.heading,
  panels = FEATURED_SHOWCASE.panels,
} = Astro.props;
---

<section class="section" id="categories" aria-label="Shop by category">
  <div class="wrap">
    <div class="sec-head center" style="margin-bottom: clamp(40px, 4vw, 56px);">
      <div>
        <span class="eyebrow center">{eyebrow}</span>
        <h2 class="h-sec">{heading.lead}<em>{heading.em}</em></h2>
      </div>
    </div>

    <div class="showcase">
      {
        panels.map((p) => (
          <a class="sc-panel" href={p.href}>
            <div class="sc-panel-bg"><Image src={p.img} alt={p.title} widths={[400, 800, 1200]} sizes="(max-width: 700px) 100vw, 25vw" /></div>
            <div class="sc-content">
              <span class="sc-cat">{p.cat}</span>
              <h3 class="sc-title">{p.title}</h3>
              <p class="sc-desc">{p.desc}</p>
            </div>
            <span class="sc-arrow" aria-hidden="true">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17 17 7M7 7h10v10" /></svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
