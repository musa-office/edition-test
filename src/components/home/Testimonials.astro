---
// ============================================================
//  Testimonials — press strip + verified-buyer quote cards.
//  Content is prop-driven; defaults in src/config/home.ts
//  (PRESS, REVIEWS).
// ============================================================
import { PRESS, REVIEWS, type Review } from '~/config/home';

interface Props {
  press?: string[];
  reviews?: Review[];
}
const { press = PRESS, reviews = REVIEWS } = Astro.props;
---

<section class="section testi" id="testimonials">
  <div class="testi-inner">
    <div class="testi-head reveal">
      <span class="eyebrow center">Press &amp; People</span>
      <h2 class="h-sec">Worn, Written &amp; <em>Remembered</em></h2>
    </div>

    <div class="press-strip reveal">
      {
        press.map((p, i) => (
          <>
            {i > 0 && <span class="press-strip-sep"></span>}
            <span class="press-strip-item">{p}</span>
          </>
        ))
      }
    </div>

    <div class="testi-carousel-wrap reveal d1">
      <div class="testi-carousel">
        {
          reviews.map((r) => (
            <div class="testi-card">
              <div class="testi-card-meta">
                <span class="testi-verified">
                  <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                  Verified Buyer
                </span>
                <span class="testi-date">{r.date}</span>
              </div>
              <div class="testi-card-stars">★★★★★</div>
              <p class="testi-card-text">{r.text}</p>
              <div class="testi-card-product">
                <span class="testi-product-label">Purchased</span>
                <span class="testi-product-name">{r.product}</span>
              </div>
              <div class="testi-card-foot">
                <div class="testi-card-avatar" style={`background:${r.avatar};`}>{r.initials}</div>
                <div class="testi-card-author-wrap">
                  <span class="testi-card-name">{r.name}</span>
                  <span class="testi-card-loc">{r.loc}</span>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
