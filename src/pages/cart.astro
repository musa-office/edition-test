---
// ============================================================
//  Cart — full-page bag view (mirrors the drawer; same store).
// ============================================================
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="Your Bag" description="Review your Édition bag and check out.">
  <section class="shop">
    <div class="wrap">
      <div class="page-intro">
        <span class="eyebrow">Your Bag</span>
        <h1>Shopping <em>bag</em></h1>
      </div>
      <div data-cartpage-root></div>
    </div>
  </section>
</BaseLayout>

<script>
  import { $cart, $cartError, $busyLines, initCart, updateItem, removeItem, checkout } from '~/stores/cart';
  import { cartLineHtml } from '~/lib/cart-render';
  import { formatMoney } from '~/lib/utils';
  import { escapeHtml } from '~/lib/dom';
  import { SITE } from '~/config/site';

  const root = document.querySelector<HTMLElement>('[data-cartpage-root]');
  const threshold = SITE.freeShippingThreshold;

  const ARROW = `<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`;

  function render() {
    if (!root) return;
    const cart = $cart.get();
    const lines = cart?.lines ?? [];
    const error = $cartError.get();
    const busy = $busyLines.get();

    if (lines.length === 0) {
      root.innerHTML = `
        <div class="shop-empty">
          <p class="se-title">Your bag is empty</p>
          <p>Discover the SS26 collection and add your favourites.</p>
          <a class="btn-primary" href="/products">Start shopping</a>
        </div>`;
      return;
    }

    const currency = cart?.cost?.subtotalAmount?.currencyCode ?? 'USD';
    const subtotal = Number(cart?.cost?.subtotalAmount?.amount ?? 0);
    const remaining = Math.max(0, threshold - subtotal);

    const rows = lines
      .map((l) => cartLineHtml(l, currency, { busy: !!busy[l.id], flush: true }))
      .join('');

    root.innerHTML = `
      <div class="cartpage">
        <div>${rows}</div>
        <aside class="cartpage-summary">
          <h2>Order Summary</h2>
          ${error ? `<div class="cart-error" role="alert">${escapeHtml(error)}</div>` : ''}
          <div class="cartpage-row"><span>Subtotal</span><span>${escapeHtml(formatMoney(subtotal, currency))}</span></div>
          <div class="cartpage-row"><span>Shipping</span><span>${remaining > 0 ? 'Calculated at checkout' : 'Free'}</span></div>
          ${remaining > 0 ? `<div class="cart-shipping-msg" style="margin-top:12px"><span>You're ${escapeHtml(formatMoney(remaining, currency))} away from free shipping</span></div>` : ''}
          <div class="cartpage-row total"><span>Total</span><span>${escapeHtml(formatMoney(subtotal, currency))}</span></div>
          <button type="button" class="cart-checkout-btn" style="margin-top:18px" data-checkout>Checkout ${ARROW}</button>
          <a class="cart-continue-link" href="/products" style="display:block;margin-top:12px">Continue Shopping</a>
        </div>
      </div>`;
  }

  function lineId(el: HTMLElement): string | undefined {
    return el.closest<HTMLElement>('.cart-item')?.dataset.id;
  }

  root?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const cart = $cart.get();
    const line = (id?: string) => cart?.lines.find((l) => l.id === id);

    if (target.closest('[data-checkout]')) return checkout();

    const dec = target.closest<HTMLElement>('[data-line-dec]');
    if (dec) {
      const l = line(lineId(dec));
      if (l) updateItem(l.id, l.quantity - 1);
      return;
    }
    const inc = target.closest<HTMLElement>('[data-line-inc]');
    if (inc) {
      const l = line(lineId(inc));
      if (l) updateItem(l.id, l.quantity + 1);
      return;
    }
    const rem = target.closest<HTMLElement>('[data-line-remove]');
    if (rem) {
      const id = lineId(rem);
      if (id) removeItem(id);
    }
  });

  initCart();
  $cart.subscribe(render);
  $cartError.subscribe(render);
  $busyLines.subscribe(render);
</script>
