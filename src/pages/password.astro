---
// ============================================================
//  Password protected — front-end template gate. Demo password:
//  "edition". A real gate would validate server-side.
// ============================================================
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/config/site';
---

<BaseLayout title="Password Protected" description="This store is password protected.">
  <section class="pw-page">
    <div class="pw-card">
      <span class="pw-lock" aria-hidden="true">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <rect x="4" y="11" width="16" height="10" rx="2" />
          <path d="M8 11V7a4 4 0 0 1 8 0v4" />
        </svg>
      </span>
      <span class="eyebrow">Opening Soon</span>
      <h1 class="pw-title">This store is <em>password protected</em></h1>
      <p class="pw-sub">We're putting the finishing touches on the SS26 collection. Enter the password to take an early look.</p>

      <form class="pw-form" id="pwForm" novalidate>
        <input type="password" placeholder="Enter password" aria-label="Store password" autocomplete="off" required />
        <button type="submit">Enter</button>
      </form>
      <p class="pw-note" id="pwNote" role="status" aria-live="polite"></p>

      <a class="pw-back" href="/">Return to {SITE.name} →</a>
    </div>
  </section>
</BaseLayout>

<script>
  // Demo gate — the theme has no server-side password. Accepts "edition".
  const form = document.getElementById('pwForm') as HTMLFormElement | null;
  const note = document.getElementById('pwNote');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const value = (form.querySelector('input') as HTMLInputElement | null)?.value.trim().toLowerCase();
    if (!note) return;
    if (value === 'edition') {
      note.textContent = 'Welcome in — redirecting…';
      note.classList.add('ok');
      window.setTimeout(() => (window.location.href = '/'), 700);
    } else {
      note.textContent = 'Sorry, that password isn’t right. (Hint: edition)';
      note.classList.remove('ok');
    }
  });
</script>
